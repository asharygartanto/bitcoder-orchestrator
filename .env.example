# ============================================================
# Bitcoder AI Orchestrator - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Untuk DEVELOPMENT: copy ke .env dan set NODE_ENV=development
# Untuk PRODUCTION: copy ke .env dan isi semua nilai dengan benar

# ============================================================
# COMMON
# ============================================================
NODE_ENV=development
COMPOSE_PROJECT_NAME=orchestrator

# ============================================================
# DOMAIN (production)
# ============================================================
APP_DOMAIN=orchestrator.gartanto.site
APP_URL=https://orchestrator.gartanto.site
FRONTEND_URL=https://orchestrator.gartanto.site

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orchestrator
POSTGRES_USER=bitcoder
POSTGRES_PASSWORD=bitcoder_dev_password
DATABASE_URL=postgresql://bitcoder:bitcoder_dev_password@localhost:5432/orchestrator?schema=public

# ============================================================
# NestJS Backend
# ============================================================
BACKEND_PORT=3002
BACKEND_URL=http://localhost:3002
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-64-characters
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# Python RAG Engine
# ============================================================
RAG_ENGINE_PORT=8000
RAG_ENGINE_URL=http://localhost:8000

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# File Storage
UPLOAD_DIR=./uploads

# ============================================================
# Bitcoder AI API (OpenAI-compatible)
# ============================================================
AI_API_KEY=your-bitcoder-api-key
AI_API_BASE_URL=https://api.bitcoder.ai/v1
AI_CHAT_MODEL=bitcoder-chat
AI_EMBEDDING_MODEL=bitcoder-embedding
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ============================================================
# Frontend
# ============================================================
VITE_API_URL=http://localhost:3002
VITE_RAG_ENGINE_URL=http://localhost:8000

# ============================================================
# VPS Deployment
# ============================================================
VPS_USER=orchestrator
VPS_HOME=/home/orchestrator
DEPLOY_DIR=/home/orchestrator/bitcoder-orchestrator

# ============================================================
# Admin Seed (for initial setup)
# ============================================================
ADMIN_EMAIL=admin@bitcoder.ai
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
ORGANIZATION_NAME=Bitcoder Default Org
ORGANIZATION_SLUG=bitcoder-default
