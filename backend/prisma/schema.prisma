generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  parentId  String?
  parent    Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  Organization[] @relation("OrgHierarchy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  contexts    Context[]
  client      Client?
  ssoConfig   SSOConfig?
  apiKeys     ApiKey[]
  licenses    License[]
  departments Department[]
}

enum ClientStatus {
  OFFLINE
  ONLINE
  SETTING_UP
  ERROR
}

model Department {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Department?  @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Department[] @relation("DeptHierarchy")
  level          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([parentId])
}

model Client {
  id              String        @id @default(cuid())
  name            String
  agentKey        String        @unique
  status          ClientStatus  @default(OFFLINE)
  lastSeenAt      DateTime?
  organizationId  String        @unique
  organization    Organization  @relation(fields: [organizationId], references: [id])
  dbConfig        Json?
  aiConfig        Json?
  storageConfig   Json?
  healthStatus    Json?
  branding        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatar         String?
  passwordHash   String?
  googleId       String?  @unique
  role           UserRole @default(USER)
  isActive       Boolean  @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  position       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastLoginAt    DateTime?

  chatSessions   ChatSession[]
  documents      Document[]
  apiConfigs     ApiConfig[]
  passwordResets PasswordReset[]
  apiKeys        ApiKey[]
  licenses       License[]

  @@index([organizationId])
  @@index([role])
  @@index([departmentId])
}

model Context {
  id             String   @id @default(cuid())
  name           String
  description    String?
  isActive       Boolean  @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents  Document[]
  apiConfigs ApiConfig[]
  chatSessions ChatSession[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  VECTORIZING
  INDEXING
  READY
  ERROR
}

model Document {
  id             String         @id @default(cuid())
  name           String
  originalName   String
  fileType       String
  fileSize       Int
  status         DocumentStatus @default(UPLOADED)
  vectorCount    Int            @default(0)
  contextId      String
  context        Context        @relation(fields: [contextId], references: [id], onDelete: Cascade)
  organizationId String
  uploadedById   String
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([contextId])
  @@index([organizationId])
  @@index([status])
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
}

model ApiConfig {
  id             String     @id @default(cuid())
  name           String
  description    String?
  endpoint       String
  method         HttpMethod @default(GET)
  headers        Json?
  bodyTemplate   Json?
  isActive       Boolean    @default(true)
  contextId      String
  context        Context    @relation(fields: [contextId], references: [id], onDelete: Cascade)
  organizationId String
  createdById    String
  createdBy      User       @relation(fields: [createdById], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([contextId])
  @@index([organizationId])
}

model ChatSession {
  id             String   @id @default(cuid())
  title          String   @default("New Chat")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  contextId      String?
  context        Context? @relation(fields: [contextId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@index([organizationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  references Json?
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

enum SSOProtocol {
  SAML
  OIDC
}

model SSOConfig {
  id              String       @id @default(cuid())
  name            String
  protocol        SSOProtocol  @default(SAML)
  isActive        Boolean      @default(false)
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id])

  entryPoint      String?
  certificate     String?
  issuer          String?

  clientId        String?
  clientSecret    String?
  discoveryUrl    String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  key            String    @unique
  prefix         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User      @relation(fields: [createdById], references: [id])
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([key])
  @@index([prefix])
}

enum LicenseDuration {
  ONE_WEEK
  ONE_MONTH
  ONE_YEAR
  CUSTOM
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PENDING
}

model License {
  id             String           @id @default(cuid())
  key            String           @unique
  companyName    String
  companyAlias   String
  contactEmail   String
  contactName    String?
  phone          String?
  duration       LicenseDuration  @default(ONE_MONTH)
  status         LicenseStatus    @default(PENDING)
  startDate      DateTime
  expiresAt      DateTime
  activatedAt    DateTime?
  lastValidatedAt DateTime?
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User             @relation(fields: [createdById], references: [id])
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([key])
  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
}
